              "host": ["{{base_url}}"],
              "path": ["filmes", "{{filme_id}}"]
            },
            "description": "Busca um filme específico pelo ID.\n\nAltere a variável filme_id na collection para testar IDs diferentes.\n\nRespostas possíveis:\n- 200 OK → filme encontrado\n- 400 Bad Request → ID não é um número válido\n- 404 Not Found → filme não existe"
          },
          "response": [
            {
              "name": "200 — Filme encontrado",
              "originalRequest": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "123" }
                ],
                "url": {
                  "raw": "{{base_url}}/filmes/1",
                  "host": ["{{base_url}}"],
                  "path": ["filmes", "1"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"titulo\": \"O Poderoso Chefao\",\n  \"genero\": \"Drama\",\n  \"duracao\": \"2h55min\",\n  \"faixaEtaria\": 18\n}"
            },
            {
              "name": "404 — Filme não encontrado",
              "originalRequest": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "123" }
                ],
                "url": {
                  "raw": "{{base_url}}/filmes/999",
                  "host": ["{{base_url}}"],
                  "path": ["filmes", "999"]
                }
              },
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"erro\": \"Filme com ID 999 não encontrado.\"\n}"
            }
