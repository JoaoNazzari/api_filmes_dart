{
  "info": {
    "name": "Filmes API — Dart + Shelf",
    "description": "Collection completa para a API REST de Filmes e Atores construída com Dart + Shelf.\n\nBase URL: http://localhost:8080\n\nEntidades:\n- Filme (pai): id, titulo, genero, duracao, faixaEtaria\n- Ator (filho): id, nome, personagem, idade, filmeId\n\nRelacionamento: 1 Filme → N Atores",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "filme_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "ator_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Filmes",
      "item": [
        {
          "name": "Listar todos os filmes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "123"
              }
            ],
            "url": {
              "raw": "{{base_url}}/filmes",
              "host": ["{{base_url}}"],
              "path": ["filmes"]
            },
            "description": "Retorna todos os filmes cadastrados, ordenados por ID decrescente.\n\nFiltros opcionais via query parameters:\n- ?idade=14 → filmes permitidos para 14 anos\n- ?genero=Acao → filmes do gênero Ação\n- ?idade=14&genero=Acao → combina os dois filtros\n\nResposta esperada: 200 OK"
          },
          "response": [
            {
              "name": "200 — Lista de filmes",
              "originalRequest": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "123" }
                ],
                "url": {
                  "raw": "{{base_url}}/filmes",
                  "host": ["{{base_url}}"],
                  "path": ["filmes"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 2,\n    \"titulo\": \"Interestelar\",\n    \"genero\": \"Ficcao Cientifica\",\n    \"duracao\": \"2h49min\",\n    \"faixaEtaria\": 12\n  },\n  {\n    \"id\": 1,\n    \"titulo\": \"O Poderoso Chefao\",\n    \"genero\": \"Drama\",\n    \"duracao\": \"2h55min\",\n    \"faixaEtaria\": 18\n  }\n]"
            }
          ]
        },
